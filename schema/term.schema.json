{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Term",
  "type": "object",
  "required": ["term", "definition", "status"],
  "properties": {
    "term": { "type": "string" },
    "definition": { "type": "string" },
    "status": { "type": "string" },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}
